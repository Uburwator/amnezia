{
  "containers": [
    {
      "container": "amnezia-awg",
      "awg": {
        "last_config": "{ <-- This is a JSON STRING containing all config details",
        "isThirdPartyConfig": true,
        "port": 55555,
        "protocol_version": "2",
        "transport_proto": "udp"
      }
    }
  ],
  "defaultContainer": "amnezia-awg",
  "description": "AmneziaWG",
  "dns1": "1.1.1.1",
  "dns2": "1.0.0.1",
  "hostName": "bl.ubur.net"
}

NOTES:
- Container: "amnezia-awg" (v1 name, NOT "amnezia-awg2")
- protocol_version: "2" tells app to use AWG v2 features
- last_config: Nested JSON string with UPPERCASE field names (Jc, S3, I1)
- port: VPN port (55555), not SSH port
- NO vpn:// prefix in Base64 QR data!
